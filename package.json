{
  "name": "videotracker",
  "version": "1.1.2",
  "description": "",
  "main": "dist-electron/index.js",
  "scripts": {
    "build:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --external:electron --outdir=dist-electron",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --external:electron --outdir=dist-electron --watch",
    "dev:renderer": "vite",
    "dev": "concurrently -k -r -n \"main,renderer,app\" -c \"magenta,cyan,blue\" \"npm run dev:main\" \"npm run dev:renderer\" \"electron .\"",
    "test:migration": "node -e \"require('fs').mkdirSync('.temp',{recursive:true})\" && esbuild tests/progressMigration.test.ts --bundle --platform=node --format=cjs --outfile=.temp/progressMigration.test.cjs && node .temp/progressMigration.test.cjs",
    "package": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "artplayer": "^5.4.0",
    "electron-updater": "^6.8.9",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.videotracker.app",
    "productName": "VideoTracker",
    "directories": {
      "output": "dist-package"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zzf-857",
        "repo": "VideoTracker"
      }
    ],
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "Assets/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoTracker"
    }
  }
}
